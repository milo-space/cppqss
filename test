import pymxs
from typing import Tuple

rt = pymxs.runtime


def print_selected_node_as_ue_fmatrix() -> None:
    selection_count = rt.selection.count

    if selection_count != 1:
        print("ノードを1つだけ選択してください。")
        print(f"現在の選択数: {selection_count}")
        return

    node = rt.selection[0]
    tm = node.transform

    a, b, c = float(tm.row1.x), float(tm.row1.y), float(tm.row1.z)
    d, e, f = float(tm.row2.x), float(tm.row2.y), float(tm.row2.z)
    g, h, i = float(tm.row3.x), float(tm.row3.y), float(tm.row3.z)
    x, y, z = float(tm.row4.x), float(tm.row4.y), float(tm.row4.z)

    x_plane: Tuple[float, float, float, float] = (a, -b, c, 0.0)
    y_plane: Tuple[float, float, float, float] = (-d, e, -f, 0.0)
    z_plane: Tuple[float, float, float, float] = (g, -h, i, 0.0)
    w_plane: Tuple[float, float, float, float] = (x, -y, z, 1.0)

    def print_plane(name: str, plane: Tuple[float, float, float, float]) -> None:
        px, py, pz, pw = plane
        print(
            f"{name}=FPlane("
            f"X={px:.2f}, Y={py:.2f}, Z={pz:.2f}, W={pw:.2f}"
            f")"
        )

    print("----- 3dsMax -> UE FMatrix -----")
    print(f"Node: {node.name}")
    print("Conversion: position [X, Y, Z] -> [X, -Y, Z]")
    print("Rotation/Scale: R_ue = C * R_max * C, C = diag(1, -1, 1)")
    print("")

    print_plane("XPlane", x_plane)
    print_plane("YPlane", y_plane)
    print_plane("ZPlane", z_plane)
    print_plane("WPlane", w_plane)
    print("")

    print("FMatrix M(")
    print(
        f"    FPlane({x_plane[0]:.2f}, {x_plane[1]:.2f}, {x_plane[2]:.2f}, {x_plane[3]:.2f}),"
    )
    print(
        f"    FPlane({y_plane[0]:.2f}, {y_plane[1]:.2f}, {y_plane[2]:.2f}, {y_plane[3]:.2f}),"
    )
    print(
        f"    FPlane({z_plane[0]:.2f}, {z_plane[1]:.2f}, {z_plane[2]:.2f}, {z_plane[3]:.2f}),"
    )
    print(
        f"    FPlane({w_plane[0]:.2f}, {w_plane[1]:.2f}, {w_plane[2]:.2f}, {w_plane[3]:.2f})"
    )
    print(");")


print_selected_node_as_ue_fmatrix()
