from collections import deque
from heapq import heappush, heappop


def update_progress(progress: int) -> None:
    pass


def pair(
    data_a: dict[tuple[int, ...], object],
    data_b: dict[tuple[int, ...], object],
) -> tuple[list[tuple[object, object]], list[object], list[object]]:
    update_progress(0)

    keys_a = sorted(data_a.keys())
    keys_b = sorted(data_b.keys())
    n = len(keys_a)
    m = len(keys_b)

    if n == 0 or m == 0:
        update_progress(100)
        return [], [data_a[k] for k in keys_a], [data_b[k] for k in keys_b]

    # --- reverse index ---
    int_to_bs: dict[int, list[int]] = {}
    for j, kb in enumerate(keys_b):
        for v in kb:
            int_to_bs.setdefault(v, []).append(j)

    # --- common item computation ---
    common_cnt: list[dict[int, int]] = [dict() for _ in range(n)]
    common_min: list[dict[int, int]] = [dict() for _ in range(n)]
    for i, ka in enumerate(keys_a):
        hits: dict[int, list[int]] = {}
        for v in ka:
            for j in int_to_bs.get(v, ()):
                hits.setdefault(j, []).append(v)
        for j, vals in hits.items():
            common_cnt[i][j] = len(vals)
            common_min[i][j] = min(vals)

    update_progress(5)

    # ============================
    # Pass1: MCMF for tier1 + tier2 optimal matching
    # ============================
    max_pairs = min(n, m)
    BASE_2 = max_pairs + 1
    max_len = max(
        max((len(ka) for ka in keys_a), default=1),
        max((len(kb) for kb in keys_b), default=1),
    )
    pow2 = [1] * (max_len + 1)
    for c in range(1, max_len + 1):
        pow2[c] = pow2[c - 1] * BASE_2
    TIER1 = pow2[-1] * BASE_2

    INF = float('inf')

    # Network: S=0, A_i=i+1 (i=0..n-1), B_j=n+1+j (j=0..m-1), T=n+m+1
    S = 0
    T = n + m + 1
    V = T + 1

    # Edge storage: edges[k] = [to, cap, cost, rev_index]
    edges: list[list] = []
    g: list[list[int]] = [[] for _ in range(V)]

    def add_edge(u: int, v: int, cap: int, cost: int) -> None:
        g[u].append(len(edges))
        edges.append([v, cap, cost, len(edges) + 1])
        g[v].append(len(edges))
        edges.append([u, 0, -cost, len(edges) - 1])

    # S -> A_i (cap=1, cost=0)
    for i in range(n):
        add_edge(S, i + 1, 1, 0)

    # A_i -> B_j (cap=1, cost=w)
    for i in range(n):
        for j, cnt in common_cnt[i].items():
            w = -(cnt * TIER1 + pow2[cnt])
            add_edge(i + 1, n + 1 + j, 1, w)

    # B_j -> T (cap=1, cost=0)
    for j in range(m):
        add_edge(n + 1 + j, T, 1, 0)

    update_progress(10)

    # MCMF: Successive shortest paths
    h = [0] * V  # Johnson potentials
    dist = [0] * V
    prev_v = [0] * V
    prev_e = [0] * V
    _edges = edges
    _g = g
    _h = h
    _dist = dist

    # First iteration: SPFA (handles negative costs)
    def spfa() -> bool:
        for i in range(V):
            _dist[i] = INF
        _dist[S] = 0
        in_q = bytearray(V)
        dq: deque[int] = deque([S])
        in_q[S] = 1
        while dq:
            u = dq.popleft()
            in_q[u] = 0
            du = _dist[u]
            for idx in _g[u]:
                e = _edges[idx]
                if e[1] > 0:
                    v = e[0]
                    nd = du + e[2]
                    if nd < _dist[v]:
                        _dist[v] = nd
                        prev_v[v] = u
                        prev_e[v] = idx
                        if not in_q[v]:
                            if dq and nd <= _dist[dq[0]]:
                                dq.appendleft(v)
                            else:
                                dq.append(v)
                            in_q[v] = 1
        return _dist[T] < INF

    # Subsequent iterations: Dijkstra with Johnson potentials
    def dijkstra() -> bool:
        for i in range(V):
            _dist[i] = INF
        _dist[S] = 0
        pq: list[tuple[int, int]] = [(0, S)]
        while pq:
            d, u = heappop(pq)
            if d > _dist[u]:
                continue
            hu = _h[u]
            for idx in _g[u]:
                e = _edges[idx]
                if e[1] > 0:
                    v = e[0]
                    nd = d + e[2] + hu - _h[v]
                    if nd < _dist[v]:
                        _dist[v] = nd
                        prev_v[v] = u
                        prev_e[v] = idx
                        heappush(pq, (nd, v))
        return _dist[T] < INF

    total_flow = 0
    total_cost = 0
    first = True

    while True:
        if first:
            found = spfa()
            first = False
        else:
            found = dijkstra()
        if not found:
            break
        # Check marginal cost: actual path cost = dist[T] + h[T] - h[S]
        marginal = dist[T] + h[T] - h[S]
        if marginal >= 0:
            break
        # Update potentials
        for i in range(V):
            if dist[i] < INF:
                h[i] += dist[i]
        # Augment along shortest path
        v = T
        while v != S:
            e_idx = prev_e[v]
            edges[e_idx][1] -= 1
            edges[edges[e_idx][3]][1] += 1
            v = prev_v[v]
        total_flow += 1
        total_cost += h[T] - h[S]
        update_progress(min(10 + 40 * total_flow // max_pairs, 50))

    # Extract matching
    match_a = [-1] * n
    match_b = [-1] * m
    matched_count = 0
    for i in range(n):
        for idx in g[i + 1]:
            e = edges[idx]
            if e[0] > n and e[0] <= n + m and e[1] == 0:
                j = e[0] - n - 1
                match_a[i] = j
                match_b[j] = i
                matched_count += 1
                break

    update_progress(50)

    if matched_count == 0:
        update_progress(100)
        return [], list(data_a.values()), list(data_b.values())

    # --- tier12-optimal subgraph via SCC on rc=0 residual graph ---
    # Use MCMF potentials h[] directly for reduced cost computation
    V_scc = n + m + 2
    S_scc = 0
    T_scc = V_scc - 1
    scc_adj: list[list[int]] = [[] for _ in range(V_scc)]

    # rc=0 unmatched forward edges: A_i -> B_j
    rc0_fwd: list[list[int]] = [[] for _ in range(n)]
    for i in range(n):
        hi = h[i + 1]
        for j, cnt in common_cnt[i].items():
            if match_a[i] == j:
                continue
            ecost = -(cnt * TIER1 + pow2[cnt])
            rc = ecost + hi - h[n + 1 + j]
            if rc == 0:
                rc0_fwd[i].append(j)
                scc_adj[i + 1].append(n + 1 + j)

    # rc=0 matched reverse edges: B_j -> A_i (always rc=0 for matched)
    for j in range(m):
        if match_b[j] >= 0:
            scc_adj[n + 1 + j].append(match_b[j] + 1)

    # S <-> A edges: rc = 0 + h[from] - h[to]
    for i in range(n):
        if match_a[i] >= 0:
            if h[i + 1] == h[S]:
                scc_adj[i + 1].append(S_scc)
        else:
            if h[S] == h[i + 1]:
                scc_adj[S_scc].append(i + 1)

    # B <-> T edges
    for j in range(m):
        if match_b[j] >= 0:
            if h[T] == h[n + 1 + j]:
                scc_adj[T_scc].append(n + 1 + j)
        else:
            if h[n + 1 + j] == h[T]:
                scc_adj[n + 1 + j].append(T_scc)

    # Iterative Tarjan's SCC
    scc_cnt = [0]
    scc_stk: list[int] = []
    scc_on: list[bool] = [False] * V_scc
    scc_low: list[int] = [0] * V_scc
    scc_num: list[int] = [-1] * V_scc
    scc_id: list[int] = [-1] * V_scc

    def _tarjan_iter(start: int) -> None:
        call_stk: list[tuple[int, int]] = [(start, 0)]
        scc_num[start] = scc_low[start] = scc_cnt[0]
        scc_cnt[0] += 1
        scc_stk.append(start)
        scc_on[start] = True
        while call_stk:
            u_t, ei = call_stk[-1]
            if ei < len(scc_adj[u_t]):
                call_stk[-1] = (u_t, ei + 1)
                v_t = scc_adj[u_t][ei]
                if scc_num[v_t] == -1:
                    scc_num[v_t] = scc_low[v_t] = scc_cnt[0]
                    scc_cnt[0] += 1
                    scc_stk.append(v_t)
                    scc_on[v_t] = True
                    call_stk.append((v_t, 0))
                elif scc_on[v_t]:
                    if scc_num[v_t] < scc_low[u_t]:
                        scc_low[u_t] = scc_num[v_t]
            else:
                if scc_low[u_t] == scc_num[u_t]:
                    cid = u_t
                    while True:
                        w_t = scc_stk.pop()
                        scc_on[w_t] = False
                        scc_id[w_t] = cid
                        if w_t == u_t:
                            break
                call_stk.pop()
                if call_stk:
                    parent = call_stk[-1][0]
                    if scc_low[u_t] < scc_low[parent]:
                        scc_low[parent] = scc_low[u_t]

    for u_t in range(V_scc):
        if scc_num[u_t] == -1:
            _tarjan_iter(u_t)

    opt_adj: list[list[int]] = [[] for _ in range(n)]
    opt_min: list[dict[int, int]] = [dict() for _ in range(n)]

    # All matched edges are always tier12-optimal
    for i in range(n):
        j = match_a[i]
        if j >= 0 and j in common_min[i]:
            opt_adj[i].append(j)
            opt_min[i][j] = common_min[i][j]

    # Unmatched rc=0 edges: tier12-optimal iff same SCC
    for i in range(n):
        for j in rc0_fwd[i]:
            if scc_id[i + 1] == scc_id[n + 1 + j]:
                opt_adj[i].append(j)
                opt_min[i][j] = common_min[i][j]

    update_progress(55)

    # ============================
    # Pass2: Lex-min sorted min_val list via greedy with incremental matching
    # ============================

    edge_cost: list[dict[int, int]] = [dict() for _ in range(n)]
    for i in range(n):
        for j in opt_adj[i]:
            cnt = common_cnt[i][j]
            edge_cost[i][j] = -(cnt * TIER1 + pow2[cnt])

    opt_total_cost = 0
    from collections import Counter
    opt_cnt_dist = Counter()
    for i in range(n):
        j = match_a[i]
        if j >= 0 and j in edge_cost[i]:
            opt_total_cost += edge_cost[i][j]
            opt_cnt_dist[common_cnt[i][j]] += 1

    # Collect all tier12-optimal edges sorted by min_val
    edges_by_mv: list[tuple[int, int, int]] = []
    for i in range(n):
        for j in opt_adj[i]:
            edges_by_mv.append((opt_min[i][j], i, j))
    edges_by_mv.sort()

    # Build reverse adjacency for opt subgraph
    opt_radj: list[list[int]] = [[] for _ in range(m)]
    for i in range(n):
        for j in opt_adj[i]:
            opt_radj[j].append(i)

    # Initialize matching from Pass1
    cur_ma = [-1] * n
    cur_mb = [-1] * m
    cur_match_size = 0
    for i in range(n):
        j = match_a[i]
        if j >= 0 and j in opt_min[i]:
            cur_ma[i] = j
            cur_mb[j] = i
            cur_match_size += 1

    avail_a = bytearray(n)
    avail_b = bytearray(m)
    for i in range(n):
        avail_a[i] = 1
    for j in range(m):
        avail_b[j] = 1

    needed = 0  # will be set in loop

    def _is_feasible(fix_i: int, fix_j: int) -> bool:
        j_partner = cur_ma[fix_i]
        i_partner = cur_mb[fix_j]

        if j_partner == fix_j:
            return True
        losses = (1 if j_partner >= 0 else 0) + (1 if i_partner >= 0 else 0)
        if losses == 0:
            return True
        if cur_match_size - losses >= needed:
            return True
        recover_needed = needed - (cur_match_size - losses)
        recovered = 0
        if j_partner >= 0:
            if _has_aug_from_b(j_partner, fix_i, fix_j):
                recovered += 1
                if recovered >= recover_needed:
                    return True
        if i_partner >= 0 and recovered < recover_needed:
            if _has_aug_from_a(i_partner, fix_i, fix_j):
                recovered += 1
                if recovered >= recover_needed:
                    return True
        return False

    def _has_aug_from_b(free_j: int, skip_i: int, skip_j: int) -> bool:
        visited_a = bytearray(n)
        q = deque()
        for i in opt_radj[free_j]:
            if i == skip_i or not avail_a[i] or visited_a[i]:
                continue
            visited_a[i] = 1
            if cur_ma[i] == -1 or cur_ma[i] == skip_j:
                return True
            q.append(i)
        while q:
            a_node = q.popleft()
            j2 = cur_ma[a_node]
            if j2 == skip_j:
                return True
            if not avail_b[j2]:
                continue
            for i in opt_radj[j2]:
                if i == skip_i or not avail_a[i] or visited_a[i]:
                    continue
                visited_a[i] = 1
                if cur_ma[i] == -1 or cur_ma[i] == skip_j:
                    return True
                q.append(i)
        return False

    def _has_aug_from_a(free_i: int, skip_i: int, skip_j: int) -> bool:
        visited_b = bytearray(m)
        q = deque()
        for j in opt_adj[free_i]:
            if j == skip_j or not avail_b[j] or visited_b[j]:
                continue
            visited_b[j] = 1
            if cur_mb[j] == -1 or cur_mb[j] == skip_i:
                return True
            q.append(j)
        while q:
            b_node = q.popleft()
            i2 = cur_mb[b_node]
            if i2 == skip_i:
                return True
            if not avail_a[i2]:
                continue
            for j in opt_adj[i2]:
                if j == skip_j or not avail_b[j] or visited_b[j]:
                    continue
                visited_b[j] = 1
                if cur_mb[j] == -1 or cur_mb[j] == skip_i:
                    return True
                q.append(j)
        return False

    def _do_aug_from_b(free_j: int) -> bool:
        prev_a = [-1] * n
        visited_a = bytearray(n)
        q = deque()
        target_a = -1
        for i in opt_radj[free_j]:
            if not avail_a[i] or visited_a[i]:
                continue
            visited_a[i] = 1
            prev_a[i] = free_j
            if cur_ma[i] == -1:
                target_a = i
                break
            q.append(i)
        if target_a == -1:
            while q:
                a_node = q.popleft()
                j2 = cur_ma[a_node]
                if not avail_b[j2]:
                    continue
                for i in opt_radj[j2]:
                    if not avail_a[i] or visited_a[i]:
                        continue
                    visited_a[i] = 1
                    prev_a[i] = j2
                    if cur_ma[i] == -1:
                        target_a = i
                        break
                    q.append(i)
                if target_a != -1:
                    break
        if target_a == -1:
            return False
        i = target_a
        while i != -1:
            j = prev_a[i]
            old_i = cur_mb[j] if j != free_j else -1
            cur_ma[i] = j
            cur_mb[j] = i
            i = old_i
        return True

    # cnt distribution tracking
    max_c_val = max(opt_cnt_dist.keys()) if opt_cnt_dist else 0
    rd_arr = [0] * (max_c_val + 1)
    for c, cnt in opt_cnt_dist.items():
        rd_arr[c] = cnt

    def _commit_edge(fix_i: int, fix_j: int) -> None:
        nonlocal cur_match_size
        lost_b = -1
        lost_a = -1
        if cur_ma[fix_i] == fix_j:
            cur_ma[fix_i] = -1
            cur_mb[fix_j] = -1
            cur_match_size -= 1
        else:
            if cur_ma[fix_i] >= 0:
                lost_b = cur_ma[fix_i]
                cur_mb[lost_b] = -1
                cur_ma[fix_i] = -1
                cur_match_size -= 1
            if cur_mb[fix_j] >= 0:
                lost_a = cur_mb[fix_j]
                cur_ma[lost_a] = -1
                cur_mb[fix_j] = -1
                cur_match_size -= 1
        avail_a[fix_i] = 0
        avail_b[fix_j] = 0
        if lost_b >= 0 and avail_b[lost_b]:
            if _do_aug_from_b(lost_b):
                cur_match_size += 1
        if lost_a >= 0 and avail_a[lost_a] and cur_ma[lost_a] == -1:
            recovered_a = False
            for j2 in opt_adj[lost_a]:
                if avail_b[j2] and cur_mb[j2] == -1:
                    cur_ma[lost_a] = j2
                    cur_mb[j2] = lost_a
                    cur_match_size += 1
                    recovered_a = True
                    break
            if not recovered_a:
                visited_b2 = bytearray(m)
                prev_b2 = [-1] * m
                q2 = deque()
                target_j2 = -1
                for j2 in opt_adj[lost_a]:
                    if not avail_b[j2] or visited_b2[j2]:
                        continue
                    visited_b2[j2] = 1
                    prev_b2[j2] = lost_a
                    if cur_mb[j2] == -1:
                        target_j2 = j2
                        break
                    q2.append(j2)
                if target_j2 == -1:
                    while q2:
                        b_node2 = q2.popleft()
                        i2 = cur_mb[b_node2]
                        if not avail_a[i2]:
                            continue
                        for j2 in opt_adj[i2]:
                            if not avail_b[j2] or visited_b2[j2]:
                                continue
                            visited_b2[j2] = 1
                            prev_b2[j2] = i2
                            if cur_mb[j2] == -1:
                                target_j2 = j2
                                break
                            q2.append(j2)
                        if target_j2 != -1:
                            break
                if target_j2 != -1:
                    j2 = target_j2
                    while j2 != -1:
                        i2 = prev_b2[j2]
                        old_j2 = cur_ma[i2] if i2 != lost_a else -1
                        cur_ma[i2] = j2
                        cur_mb[j2] = i2
                        j2 = old_j2
                    cur_match_size += 1
        c_fix = common_cnt[fix_i][fix_j]
        rd_arr[c_fix] -= 1

    fixed: list[tuple[int, int]] = []
    edge_start = 0
    num_edges = len(edges_by_mv)

    for pos in range(matched_count):
        needed = matched_count - pos - 1

        # Advance start pointer past permanently dead edges
        while edge_start < num_edges:
            mv, i, j = edges_by_mv[edge_start]
            if not avail_a[i] or not avail_b[j]:
                edge_start += 1
                continue
            c = common_cnt[i][j]
            if c > max_c_val or rd_arr[c] <= 0:
                edge_start += 1
                continue
            break

        # Collect feasible edges at the smallest min_val
        feasible_at_min: list[tuple[int, int]] = []
        best_mv = None

        for eidx in range(edge_start, num_edges):
            mv, i, j = edges_by_mv[eidx]
            if not avail_a[i] or not avail_b[j]:
                continue
            c = common_cnt[i][j]
            if c > max_c_val or rd_arr[c] <= 0:
                continue
            if best_mv is not None and mv > best_mv:
                break
            if needed > 0:
                if not _is_feasible(i, j):
                    continue
            if best_mv is None:
                best_mv = mv
            feasible_at_min.append((i, j))

        if not feasible_at_min:
            break

        if len(feasible_at_min) == 1:
            i_fix, j_fix = feasible_at_min[0]
        else:
            # Tie-break: simulate greedy continuation with feasibility
            save_ma = cur_ma[:]
            save_mb = cur_mb[:]
            save_ms = cur_match_size
            save_aa = bytearray(avail_a)
            save_ab = bytearray(avail_b)
            save_rd = rd_arr[:]

            best_ij = feasible_at_min[0]
            best_cont = None

            for ci in range(len(feasible_at_min)):
                i_try, j_try = feasible_at_min[ci]

                # Restore to pre-simulation state
                cur_ma[:] = save_ma
                cur_mb[:] = save_mb
                cur_match_size = save_ms
                avail_a[:] = save_aa
                avail_b[:] = save_ab
                rd_arr[:] = save_rd

                # Commit candidate with full matching update
                _commit_edge(i_try, j_try)

                cont = []
                beaten = False
                sim_es = edge_start

                for p2 in range(matched_count - pos - 1):
                    needed = matched_count - pos - 2 - p2

                    # Advance past permanently dead edges
                    while sim_es < num_edges:
                        mv2, i2, j2 = edges_by_mv[sim_es]
                        if not avail_a[i2] or not avail_b[j2]:
                            sim_es += 1
                            continue
                        c2 = common_cnt[i2][j2]
                        if c2 > max_c_val or rd_arr[c2] <= 0:
                            sim_es += 1
                            continue
                        break

                    # Find first feasible edge
                    found_mv2 = -1
                    found_i2 = -1
                    found_j2 = -1
                    for eidx2 in range(sim_es, num_edges):
                        mv2, i2, j2 = edges_by_mv[eidx2]
                        if not avail_a[i2] or not avail_b[j2]:
                            continue
                        c2 = common_cnt[i2][j2]
                        if c2 > max_c_val or rd_arr[c2] <= 0:
                            continue
                        if needed > 0 and not _is_feasible(i2, j2):
                            continue
                        found_mv2 = mv2
                        found_i2 = i2
                        found_j2 = j2
                        break

                    if found_mv2 == -1:
                        break

                    cont.append(found_mv2)
                    _commit_edge(found_i2, found_j2)

                    # Early termination
                    if best_cont is not None and p2 < len(best_cont):
                        if cont[p2] > best_cont[p2]:
                            beaten = True
                            break
                        elif cont[p2] < best_cont[p2]:
                            break

                if not beaten and (best_cont is None or cont < best_cont):
                    best_cont = cont
                    best_ij = (i_try, j_try)

            # Restore original state
            cur_ma[:] = save_ma
            cur_mb[:] = save_mb
            cur_match_size = save_ms
            avail_a[:] = save_aa
            avail_b[:] = save_ab
            rd_arr[:] = save_rd

            i_fix, j_fix = best_ij

        # Commit
        fixed.append((i_fix, j_fix))
        _commit_edge(i_fix, j_fix)

    # Verify; fall back to original matching if needed
    if len(fixed) == matched_count:
        actual_cost = sum(edge_cost[i][j] for i, j in fixed)
        if actual_cost != opt_total_cost:
            fixed = [(i, match_a[i]) for i in range(n) if match_a[i] >= 0]
    else:
        fixed = [(i, match_a[i]) for i in range(n) if match_a[i] >= 0]

    update_progress(95)

    # Build output
    paired = []
    ua_set: set[int] = set()
    ub_set: set[int] = set()
    for i, j in fixed:
        paired.append((data_a[keys_a[i]], data_b[keys_b[j]]))
        ua_set.add(i)
        ub_set.add(j)

    unpaired_a = [data_a[keys_a[i]] for i in range(n) if i not in ua_set]
    unpaired_b = [data_b[keys_b[j]] for j in range(m) if j not in ub_set]

    update_progress(100)
    return paired, unpaired_a, unpaired_b
